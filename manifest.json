{
  "manifest_version": 3,
  "name": "SORA Prompt + Image Downloader",
  "description": "Scan a page for generated images and prompts, then download both image files and JSON metadata.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "unlimitedStorage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "SORA Downloader",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
